generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id           String   @id @default(uuid())
  domain       String   @unique
  name         String
  tagId        String
  tagSlug      String
  description  String?
  primaryColor String   @default("#f7931a")
  accentColor  String   @default("#0d0d0d")
  textColor    String   @default("#ffffff")
  logoUrl      String?
  faviconUrl   String?
  metaTitle    String?
  metaDesc     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
